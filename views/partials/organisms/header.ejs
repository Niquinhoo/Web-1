<header class="main-header">
    <% const safeCartItemCount = Number.isFinite(Number(cartItemCount)) ? Number(cartItemCount) : 0; %>
    <div class="header-container">
        <a href="/" class="header-logo">
            <span class="logo-text">Pediloo</span>
        </a>
        <a href="/cart" class="header-cart" aria-label="Ver carrito">
            <span class="header-cart-icon">🛒</span>
            <span class="header-cart-count"><%= safeCartItemCount %></span>
        </a>
        <nav class="header-nav">
            <a href="/login" class="nav-link nav-btn-empty">Iniciar Sesión</a>
            <a href="/register" class="nav-link nav-btn">Registrarse</a>
        </nav>
    </div>
</header>
