<article class="cart-item">
    <div class="cart-item-image">
        <%- include('../../atoms/cart/cart-item-image', {
            image: item.src,
            title: item.title
        }) %>
    </div>
    <div class="cart-item-info">
        <%- include('../../atoms/cart/cart-item-title', { title: item.title }) %>
        <p class="item-meta"><%= item.category %></p>
        <p class="item-unit-price">Precio unitario: $<%= item.unitPrice %></p>
        <%- include('../../molecules/cart/cart-item-actions', {
            quantity: item.quantity,
            productId: item.productId
        }) %>
    </div>
    <div class="cart-item-price-wrapper">
        <%- include('../../atoms/cart/cart-item-price', { price: '$' + item.subtotal }) %>
        <span class="item-price-label">Subtotal</span>
    </div>
    <form action="/cart/items/<%= item.productId %>/remove" method="POST">
        <button type="submit" class="cart-item-remove" aria-label="Eliminar producto" title="Eliminar">&times;</button>
    </form>
</article>
