<%- include('../partials/header') %>

<main class="container">
  <div class="back-nav">
    <a href="/tasks" class="btn-back">
      <span class="material-symbols-outlined" style="font-size:1rem;">arrow_back</span>
      Volver a la lista
    </a>
  </div>

  <div class="detail-card">
    <div class="detail-header">
      <div>
        <span class="label-eyebrow">
          <span class="file-badge">TAREA #<%= task.id %></span>
        </span>
        <h1><%= task.title %></h1>
      </div>
      <div class="difficulty-badge large">
        <span class="label">Dificultad:</span>
        <% for(let i = 1; i <= 3; i++) { %>
          <span class="star <%= i <= task.difficulty ? 'filled' : '' %>">★</span>
        <% } %>
      </div>
    </div>

    <div class="detail-body">
      <h2>
        <span class="material-symbols-outlined" style="font-size:0.95rem;vertical-align:middle;margin-right:4px;">description</span>
        Descripción
      </h2>
      <p class="task-description"><%= task.description %></p>
    </div>

    <div class="detail-footer">
      <span class="task-id">tasks.model.js · id: <%= task.id %></span>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
