<%- include('../partials/header') %>

<main class="container">
  <div class="back-nav">
    <a href="/tasks" class="btn-back">← Volver a la lista</a>
  </div>

  <div class="detail-card">
    <div class="detail-header">
      <h1><%= task.title %></h1>
      <div class="difficulty-badge large">
        <span class="label">Dificultad:</span>
        <% for(let i = 1; i <= 3; i++) { %>
          <span class="star <%= i <= task.difficulty ? 'filled' : '' %>">★</span>
        <% } %>
      </div>
    </div>

    <div class="detail-body">
      <h2>Descripción</h2>
      <p class="task-description"><%= task.description %></p>
    </div>

    <div class="detail-footer">
      <span class="task-id">Tarea #<%= task.id %></span>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
