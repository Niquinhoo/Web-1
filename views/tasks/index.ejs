<%- include('../partials/header') %>

<main class="container">
  <div class="page-header">
    <span class="label-eyebrow">
      <span class="material-symbols-outlined" style="font-size:0.9rem;vertical-align:middle;">checklist</span>
      Todas las tareas
    </span>
    <h1>Lista de Tareas</h1>
    <p class="subtitle">Hacé clic en una tarea para ver su detalle</p>
  </div>

  <ul class="task-list">
    <% tasks.forEach(t => { %>
      <li class="task-card difficulty-<%= t.difficulty %>">
        <a href="/tasks/<%= t.id %>" class="task-link">
          <div class="task-info">
            <span class="task-title"><%= t.title %></span>
            <span class="task-description"><%= t.description %></span>
          </div>
          <div class="task-meta">
            <div class="difficulty-badge">
              <% for(let i = 1; i <= 3; i++) { %>
                <span class="star <%= i <= t.difficulty ? 'filled' : '' %>">★</span>
              <% } %>
            </div>
            <span class="material-symbols-outlined arrow">arrow_forward</span>
          </div>
        </a>
      </li>
    <% }) %>
  </ul>
</main>

<%- include('../partials/footer') %>
